# Copy this file to .env and fill in your values

# Required: Get free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: LLM configuration
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0
GROQ_MAX_TOKENS=1024

# Optional: Data path
DATA_PATH=data/support_tickets.csv

# Optional: Anomaly detection thresholds
ANOMALY_Z_THRESHOLD=3.0
CRITICAL_TICKET_HOURS_THRESHOLD=24
HIGH_PRIORITY_HOURS_THRESHOLD=48
MIN_AGENT_RATING=2.5

# Optional: App settings
DEBUG=false
